{
  "$schema": "https://opencode.ai/config.json",
  "model": "ccr/deepseek,deepseek-chat",
  "provider": {
    "ccr": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "CCR Proxy",
      "options": {
        "baseURL": "http://localhost:4096/v1"
      },
      "models": {
        "deepseek,deepseek-chat": {
          "name": "DeepSeek Chat (via CCR)"
        },
        "deepseek,deepseek-reasoner": {
          "name": "DeepSeek Reasoner (via CCR)"
        },
        "glm,glm-4-flash": {
          "name": "GLM-4 Flash (via CCR)"
        },
        "gemini,gemini-2.5-pro": {
          "name": "Gemini 2.5 Pro (via CCR)"
        },
        "openai,gpt-4o": {
          "name": "GPT-4o (via CCR)"
        }
      }
    }
  },
  "mcp": {
    "ccr-semantic": {
      "type": "remote",
      "url": "http://localhost:4096/api/mcp",
      "enabled": true
    }
  },
  "plugin": [],
  "compaction": {
    "auto": true,
    "reserved": 10000
  }
}
