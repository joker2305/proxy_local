{
  "HOST": "127.0.0.1",
  "PORT": 3456,
  "APIKEY": "local-dev-key",
  "LOG": true,
  "LOG_LEVEL": "info",
  "API_TIMEOUT_MS": 600000,

  "Providers": [
    {
      "name": "deepseek",
      "api_base_url": "https://api.deepseek.com/chat/completions",
      "api_key": "${DEEPSEEK_API_KEY}",
      "models": ["deepseek-v4-pro", "deepseek-v4-flash"],
      "transformer": {
        "use": ["deepseek"],
        "deepseek-v4-pro": { "use": ["deepseek"] },
        "deepseek-v4-flash": { "use": ["deepseek"] }
      },
      "priority": 1
    }
  ],

  "Router": {
    "default": "deepseek,deepseek-v4-pro",
    "background": "deepseek,deepseek-v4-flash",
    "think": "deepseek,deepseek-v4-pro",
    "longContext": "deepseek,deepseek-v4-pro",
    "longContextThreshold": 60000,
    "reasoningFlash": "deepseek,deepseek-v4-flash",
    "reasoningProMax": "deepseek,deepseek-v4-pro"
  },

  "ModelMapping": {
    "claude-opus-4-6": "deepseek,deepseek-v4-pro",
    "claude-opus-4-20250514": "deepseek,deepseek-v4-pro",
    "claude-opus-4": "deepseek,deepseek-v4-pro",
    "opus": "deepseek,deepseek-v4-pro",
    "claude-sonnet-4-6": "deepseek,deepseek-v4-flash",
    "claude-sonnet-4-20250514": "deepseek,deepseek-v4-flash",
    "claude-sonnet-4": "deepseek,deepseek-v4-flash",
    "sonnet": "deepseek,deepseek-v4-flash",
    "claude-haiku-4-5-20251213": "deepseek,deepseek-v4-flash",
    "claude-haiku-4-5": "deepseek,deepseek-v4-flash",
    "haiku": "deepseek,deepseek-v4-flash"
  },

  "Concurrency": {
    "global": 10,
    "providers": {
      "deepseek": 5
    },
    "queueTimeoutMs": 120000
  },

  "fallback": {
    "default": ["deepseek,deepseek-v4-flash"],
    "think": ["deepseek,deepseek-v4-flash"],
    "longContext": ["deepseek,deepseek-v4-flash"]
  }
}
